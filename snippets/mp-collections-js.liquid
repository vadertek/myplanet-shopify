<script>
  (function () {
    function initCollectionGrid() {
      const root = document.getElementById('mp-collection-grid-{{ section.id }}');
      if (!root || root.collectionGridReady) return;

      root.collectionGridReady = true;

      {%- for block in section.blocks -%}
        const button{{ forloop.index }} = document.getElementById('collection-tag-button-{{ section.id }}-{{ block.id }}');
        const panel{{ forloop.index }} = document.getElementById('collection-tag-panel-{{ section.id }}-{{ block.id }}');
      {%- endfor -%}

      const buttons = [
        {%- for block in section.blocks -%}
          button{{ forloop.index }}{% unless forloop.last %},{% endunless %}
        {%- endfor -%}
      ].filter(Boolean);

      const panels = [
        {%- for block in section.blocks -%}
          panel{{ forloop.index }}{% unless forloop.last %},{% endunless %}
        {%- endfor -%}
      ].filter(Boolean);

      function setActive(index) {
        buttons.forEach(function (button, buttonIndex) {
          const active = buttonIndex === index;

          button.setAttribute('aria-selected', String(active));
          button.classList.toggle({{ active_bg_class | json }}, active);
          button.classList.toggle('text-white', active);
          button.classList.toggle('bg-[#C0D7ED]/30', !active);
          button.classList.toggle({{ inactive_text_class | json }}, !active);
        });

        panels.forEach(function (panel, panelIndex) {
          panel.classList.toggle('hidden', panelIndex !== index);
        });
      }

      buttons.forEach(function (button, index) {
        button.addEventListener('click', function () {
          setActive(index);
        });
      });
    }

    if (document.readyState === 'loading') {
      document.addEventListener('DOMContentLoaded', initCollectionGrid);
    } else {
      initCollectionGrid();
    }

    document.addEventListener('shopify:section:load', function (event) {
      if (event.target && event.target.querySelector('#mp-collection-grid-{{ section.id }}')) {
        initCollectionGrid();
      }
    });
  })();
</script>
