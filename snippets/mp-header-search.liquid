<style>
  #mp-header-search-results-{{ section.id }}::-webkit-scrollbar {
    width: 6px;
  }

  #mp-header-search-results-{{ section.id }}::-webkit-scrollbar-track {
    background: transparent;
  }

  #mp-header-search-results-{{ section.id }}::-webkit-scrollbar-thumb {
    background-color: #0084d4;
    border-radius: 9999px;
  }

  #mp-header-search-results-{{ section.id }} {
    scrollbar-width: thin;
    scrollbar-color: #0084d4 transparent;
  }

  #mp-header-search-input-{{ section.id }}::-webkit-search-cancel-button {
    -webkit-appearance: none;
    height: 0;
    width: 0;
  }
</style>

<button id="mp-header-search-open-{{ section.id }}" class="hidden cursor-pointer md:block" type="button" aria-label="Пошук">
  <img loading="eager" class="h-4" src="{{ 'search-icon.svg' | asset_url }}" alt="Пошук">
</button>

<div
  id="mp-header-search-modal-{{ section.id }}"
  class="fixed inset-0 z-[9999] hidden items-start justify-center bg-black/70 p-4 pt-20 md:p-10"
  aria-hidden="true"
>
  <div class="mx-auto flex max-h-[80vh] w-full max-w-[760px] flex-col overflow-hidden rounded-2xl bg-white shadow-xl">
    <div class="flex shrink-0 items-center gap-3 border-b border-[#C0D7ED] px-4 py-4 md:px-5">
      <svg
        xmlns="http://www.w3.org/2000/svg"
        class="w-5 h-5 {% if template.suffix != 'nk' %} text-gray-500 {% else %} text-nk-blue {% endif %}"
        fill="none"
        viewBox="0 0 24 24"
        stroke="currentColor"
      >
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5"
          d="M21 21l-4.35-4.35M10 18a8 8 0 100-16 8 8 0 000 16z" />
      </svg>

      <form id="mp-header-search-form-{{ section.id }}" action="{{ routes.search_url }}" method="get" class="flex-1">
        <input
          id="mp-header-search-input-{{ section.id }}"
          class="w-full bg-transparent font-montserrat-reg text-[16px] leading-none text-main-blue outline-none placeholder:text-[#C0D7ED]"
          type="search"
          name="q"
          placeholder="Пошук"
          autocomplete="off"
        >
      </form>

      <button
        id="mp-header-search-close-{{ section.id }}"
        class="grid h-8 w-8 shrink-0 cursor-pointer place-items-center rounded-full bg-[#C0D7ED]/20 font-montserrat-bold text-[24px] leading-none text-main-blue transition hover:bg-[#C0D7ED]/35"
        type="button"
        aria-label="Закрити пошук"
      >
        &times;
      </button>
    </div>

    <div id="mp-header-search-results-{{ section.id }}" class="hidden overflow-y-auto p-4 md:p-5">
      <p class="mb-3 font-montserrat-bold text-[14px] leading-none font-bold text-main-blue">Результати</p>
      <div id="mp-header-search-grid-{{ section.id }}" class="grid grid-cols-1 gap-3 md:grid-cols-3 md:gap-4"></div>
    </div>
  </div>
</div>

<script>
  (function () {
    function initHeaderSearch() {
      const openBtn = document.getElementById('mp-header-search-open-{{ section.id }}');
      const modal = document.getElementById('mp-header-search-modal-{{ section.id }}');
      const closeBtn = document.getElementById('mp-header-search-close-{{ section.id }}');
      const input = document.getElementById('mp-header-search-input-{{ section.id }}');
      const results = document.getElementById('mp-header-search-results-{{ section.id }}');
      const grid = document.getElementById('mp-header-search-grid-{{ section.id }}');
      let controller = null;

      if (!openBtn || !modal || !closeBtn || !input || !results || !grid || openBtn.searchReady) return;
      openBtn.searchReady = true;

      function openModal() {
        modal.classList.remove('hidden');
        modal.classList.add('flex');
        modal.setAttribute('aria-hidden', 'false');
        document.body.classList.add('overflow-hidden');

        setTimeout(function () {
          input.focus();
        }, 100);
      }

      function closeModal() {
        modal.classList.add('hidden');
        modal.classList.remove('flex');
        modal.setAttribute('aria-hidden', 'true');
        document.body.classList.remove('overflow-hidden');
        input.value = '';
        grid.innerHTML = '';
        results.classList.add('hidden');
      }

      function renderProducts(products) {
        if (!products.length) {
          grid.innerHTML = '<p class="font-montserrat-reg text-[14px] leading-tight text-[#C0D7ED] md:col-span-3">Нічого не знайдено</p>';
          results.classList.remove('hidden');
          return;
        }

        grid.innerHTML = products
          .map(function (product) {
            const price = Number(product.price);
            const hasPrice = Number.isFinite(price) && price > 0;
            const image = product.image
              ? '<img class="h-full w-full object-contain transition group-hover:scale-[1.03]" src="' + product.image + '" alt="' + product.title + '" loading="lazy">'
              : '<div class="flex h-full w-full items-center justify-center bg-[#C0D7ED]/20 font-montserrat-bold text-[12px] text-main-blue">My Planet</div>';

            return (
              '<a class="group overflow-hidden rounded-2xl border border-[#C0D7ED] bg-white transition hover:border-main-blue" href="' +
              product.url +
              '">' +
              '<div class="aspect-square bg-[#C0D7ED]/10 p-3">' +
              image +
              '</div>' +
              '<div class="p-3">' +
              '<p class="line-clamp-2 font-montserrat-bold text-[14px] leading-tight font-bold text-main-blue">' +
              product.title +
              '</p>' +
              (hasPrice ? '<p class="mt-2 font-montserrat-bold text-[14px] leading-none font-bold text-dark-blue">' + price + ' {{ cart.currency.iso_code }}</p>' : '') +
              '</div>' +
              '</a>'
            );
          })
          .join('');

        results.classList.remove('hidden');
      }

      openBtn.addEventListener('click', openModal);
      closeBtn.addEventListener('click', closeModal);

      modal.addEventListener('click', function (event) {
        if (event.target === modal) closeModal();
      });

      document.addEventListener('keydown', function (event) {
        if (event.key === 'Escape' && !modal.classList.contains('hidden')) closeModal();
      });

      input.addEventListener('input', function () {
        const q = input.value.trim();

        if (q.length < 2) {
          results.classList.add('hidden');
          grid.innerHTML = '';
          return;
        }

        if (controller) controller.abort();
        controller = new AbortController();

        fetch('/search/suggest.json?q=' + encodeURIComponent(q) + '&resources[type]=product&resources[limit]=20', {
          signal: controller.signal,
        })
          .then(function (response) {
            return response.json();
          })
          .then(function (data) {
            const products = data.resources && data.resources.results && data.resources.results.products ? data.resources.results.products : [];
            renderProducts(products);
          })
          .catch(function () {});
      });
    }

    if (document.readyState === 'loading') {
      document.addEventListener('DOMContentLoaded', initHeaderSearch);
    } else {
      initHeaderSearch();
    }

    document.addEventListener('shopify:section:load', function (event) {
      if (event.target && event.target.querySelector('#mp-header-search-open-{{ section.id }}')) {
        initHeaderSearch();
      }
    });
  })();
</script>
