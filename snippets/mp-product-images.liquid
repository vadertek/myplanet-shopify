{%- liquid
  assign gallery_id = product.id | default: section.id
-%}

<!-- Images -->
<div class="md:w-1/2">
  <div class="px-4">
    <div id="product-gallery-swiper-{{ gallery_id }}" class="swiper flex w-full overflow-hidden">
      <div class="swiper-wrapper flex">
        {%- if product.images.size > 0 -%}
          {%- for image in product.images -%}
            <div class="swiper-slide">
              <button
                class="relative flex aspect-square w-full cursor-zoom-in items-center justify-center"
                type="button"
                value="{{ forloop.index0 }}"
                aria-label="Відкрити фото"
              >
                {{ image | image_url: width: 1000 | image_tag: class: 'max-h-full max-w-full object-contain', loading: 'eager', alt: product.title }}
              </button>
            </div>
          {%- endfor -%}
        {%- else -%}
          <div class="swiper-slide">
            <button
              class="relative flex aspect-square w-full cursor-zoom-in items-center justify-center"
              type="button"
              value="0"
              aria-label="Відкрити фото"
            >
              <img class="max-h-full max-w-full object-contain" src="{{ 'product.webp' | asset_url }}" alt="{{ product.title }}">
            </button>
          </div>
        {%- endif -%}
      </div>
    </div>

    <div class="mt-2 flex items-center justify-between md:mt-4">
      <div
        id="product-gallery-pagination-{{ gallery_id }}"
        class="flex h-7 min-w-17 items-center justify-center rounded-full bg-[#C0D7ED]/20 px-3 font-montserrat-med text-[14px] leading-none font-medium text-main-blue md:h-9 md:min-w-[91px] md:text-[18px]"
      ></div>

      <div
        class="flex h-7 w-16 overflow-hidden rounded-full bg-[#C0D7ED]/20 md:h-9 md:w-22"
        aria-label="Product photo navigation"
      >
        <button
          id="product-gallery-prev-{{ gallery_id }}"
          class="grid h-7 w-8 cursor-pointer place-items-center text-main-blue transition hover:bg-white/45 focus-visible:bg-white/45 md:h-9 md:w-11 [&.swiper-button-disabled]:cursor-default [&.swiper-button-disabled]:bg-white/45 [&.swiper-button-disabled]:text-[#C0D7ED]"
          type="button"
          aria-label="Previous photo"
        >
          <span class="h-3 w-3 rotate-45 border-b-2 border-l-2 border-current md:h-4 md:w-4" aria-hidden="true"></span>
        </button>
        <button
          id="product-gallery-next-{{ gallery_id }}"
          class="grid h-7 w-8 cursor-pointer place-items-center text-main-blue transition hover:bg-white/45 focus-visible:bg-white/45 md:h-9 md:w-11 [&.swiper-button-disabled]:cursor-default [&.swiper-button-disabled]:bg-white/45 [&.swiper-button-disabled]:text-[#C0D7ED]"
          type="button"
          aria-label="Next photo"
        >
          <span class="h-3 w-3 rotate-225 border-b-2 border-l-2 border-current md:h-4 md:w-4" aria-hidden="true"></span>
        </button>
      </div>
    </div>
  </div>
</div>

<div
  id="product-gallery-modal-{{ gallery_id }}"
  class="fixed inset-0 z-[9999] hidden items-center justify-center bg-black/70"
  aria-hidden="true"
>
  <div class="relative flex max-h-[94dvh] w-[94vw] flex-col items-center gap-3 px-3 pt-4 pb-3 md:max-h-[92vh] md:w-[min(92vw,1100px)] md:gap-4 md:px-4 md:pt-6 md:pb-4">
    <button
      id="product-gallery-modal-close-{{ gallery_id }}"
      type="button"
      class="absolute top-0 right-1 z-10 cursor-pointer px-2 font-montserrat-bold text-[42px] leading-none text-white transition hover:scale-110 md:right-2 md:text-[72px]"
      aria-label="Закрити галерею"
    >
      &times;
    </button>

    <div class="flex aspect-square w-full items-center justify-center bg-transparent pt-8 md:h-[min(68vh,760px)] md:aspect-auto md:pt-10">
      <img
        id="product-gallery-modal-image-{{ gallery_id }}"
        class="max-h-full max-w-full object-contain"
        src="{% if product.images.size > 0 %}{{ product.images.first | image_url: width: 1800 }}{% else %}{{ 'product.webp' | asset_url }}{% endif %}"
        alt="{{ product.title }}"
      >
    </div>

    <div class="w-full max-w-[760px] overflow-x-auto py-1">
      <div id="product-gallery-modal-thumbs-{{ gallery_id }}" class="flex items-center justify-start gap-2 md:justify-center md:gap-3">
        {%- if product.images.size > 0 -%}
          {%- for image in product.images -%}
            <button
              class="h-14 w-14 shrink-0 cursor-pointer overflow-hidden rounded-2xl border border-[#C0D7ED] bg-white p-1 opacity-70 transition md:h-20 md:w-20"
              type="button"
              value="{{ image | image_url: width: 1800 }}"
              aria-label="Фото {{ forloop.index }}"
            >
              {{ image | image_url: width: 200 | image_tag: class: 'h-full w-full object-contain', loading: 'lazy', alt: product.title }}
            </button>
          {%- endfor -%}
        {%- else -%}
          <button
            class="h-14 w-14 shrink-0 cursor-pointer overflow-hidden rounded-2xl border border-[#C0D7ED] bg-white p-1 opacity-70 transition md:h-20 md:w-20"
            type="button"
            value="{{ 'product.webp' | asset_url }}"
            aria-label="Фото 1"
          >
            <img class="h-full w-full object-contain" src="{{ 'product.webp' | asset_url }}" alt="{{ product.title }}">
          </button>
        {%- endif -%}
      </div>
    </div>
  </div>
</div>

<!-- Product Gallery Swiper Script -->
<script>
  (function () {
    function initProductGalleryModal() {
      const modal = document.getElementById('product-gallery-modal-{{ gallery_id }}');
      const modalImage = document.getElementById('product-gallery-modal-image-{{ gallery_id }}');
      const closeBtn = document.getElementById('product-gallery-modal-close-{{ gallery_id }}');
      const thumbs = Array.from(document.querySelectorAll('#product-gallery-modal-thumbs-{{ gallery_id }} button'));
      const openButtons = Array.from(document.querySelectorAll('#product-gallery-swiper-{{ gallery_id }} .swiper-slide button'));
      let activeIndex = 0;

      if (!modal || !modalImage || !thumbs.length) return;
      if (modal.productGalleryReady) return;
      modal.productGalleryReady = true;

      function updateActiveThumb() {
        thumbs.forEach(function (thumb, index) {
          const active = index === activeIndex;

          thumb.classList.toggle('border-main-blue', active);
          thumb.classList.toggle('border-[#C0D7ED]', !active);
          thumb.classList.toggle('opacity-100', active);
          thumb.classList.toggle('opacity-70', !active);
        });
      }

      function openByIndex(index) {
        const nextIndex = Number(index);
        if (Number.isNaN(nextIndex) || !thumbs[nextIndex]) return;

        activeIndex = nextIndex;
        modalImage.src = thumbs[activeIndex].value;
        updateActiveThumb();
        modal.classList.remove('hidden');
        modal.classList.add('flex');
        modal.setAttribute('aria-hidden', 'false');
        document.body.classList.add('overflow-hidden');
      }

      function closeModal() {
        modal.classList.add('hidden');
        modal.classList.remove('flex');
        modal.setAttribute('aria-hidden', 'true');
        document.body.classList.remove('overflow-hidden');
      }

      openButtons.forEach(function (button) {
        button.addEventListener('click', function () {
          openByIndex(button.value);
        });
      });

      thumbs.forEach(function (thumb, index) {
        thumb.addEventListener('click', function () {
          openByIndex(index);
        });
      });

      closeBtn?.addEventListener('click', closeModal);

      modal.addEventListener('click', function (event) {
        if (event.target === modal) closeModal();
      });

      document.addEventListener('keyup', function (event) {
        if (event.key === 'Escape') closeModal();
      });

      updateActiveThumb();
    }

    function initProductGallerySwiper() {
      const swiperEl = document.getElementById('product-gallery-swiper-{{ gallery_id }}');
      if (!swiperEl || typeof Swiper === 'undefined') return;

      if (swiperEl.swiper) swiperEl.swiper.destroy(true, true);

      const formatSlideNumber = function (number) {
        return String(number).padStart(2, '0');
      };

      new Swiper(swiperEl, {
        slidesPerView: 1,
        speed: 350,
        watchOverflow: true,
        navigation: {
          prevEl: '#product-gallery-prev-{{ gallery_id }}',
          nextEl: '#product-gallery-next-{{ gallery_id }}',
        },
        pagination: {
          el: '#product-gallery-pagination-{{ gallery_id }}',
          type: 'fraction',
          formatFractionCurrent: formatSlideNumber,
          formatFractionTotal: formatSlideNumber,
          renderFraction: function (currentClass, totalClass) {
            return '<span class="' + currentClass + '"></span><span class="px-1 text-[#C0D7ED]">/</span><span class="' + totalClass + '"></span>';
          },
        },
      });
    }

    if (document.readyState === 'loading') {
      document.addEventListener('DOMContentLoaded', function () {
        initProductGallerySwiper();
        initProductGalleryModal();
      });
    } else {
      initProductGallerySwiper();
      initProductGalleryModal();
    }

    document.addEventListener('shopify:section:load', function (event) {
      if (event.target && event.target.querySelector('#product-gallery-swiper-{{ gallery_id }}')) {
        initProductGallerySwiper();
        initProductGalleryModal();
      }
    });
  })();
</script>
