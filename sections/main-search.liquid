{%- liquid
  assign only_products = false
  assign only_pages = false
  if search.types.size == 1 and search.types contains 'product'
    assign only_products = true
  endif
  if search.types.size >= 1 and only_products == false
    unless search.types contains 'product'
      assign only_pages = true
    endunless
  endif
  assign encoded_terms = search.terms | url_encode
-%}

<section class="mx-auto max-w-360 bg-white px-4 py-8 md:px-8 md:py-14">
  <div class="mx-auto max-w-340">
    <h1 class="font-montserrat-bold text-[24px] leading-none font-bold text-main-blue md:text-[36px]">Пошук</h1>

    <form action="{{ routes.search_url }}" method="get" role="search" class="mt-6 flex max-w-160 items-center gap-3 rounded-2xl border border-[#C0D7ED] px-4 py-3 md:mt-8 md:px-5 md:py-4">
      <img class="h-5 w-5 shrink-0" src="{{ 'search-icon.svg' | asset_url }}" alt="" aria-hidden="true">
      <input
        class="w-full bg-transparent font-montserrat-reg text-[14px] leading-none text-main-blue outline-none placeholder:text-[#C0D7ED] md:text-[16px]"
        type="search"
        name="q"
        value="{{ search.terms | escape }}"
        placeholder="Що шукаємо?"
        autocomplete="off"
      >
      <button
        class="hidden shrink-0 cursor-pointer rounded-[10px] bg-main-blue px-5 py-2 font-montserrat-bold text-[12px] leading-none font-bold text-white transition hover:bg-dark-blue focus-visible:bg-dark-blue md:block"
        type="submit"
      >
        Знайти
      </button>
    </form>

    {%- if search.performed -%}
      {%- if search.results_count > 0 -%}
        <div class="mt-6 flex flex-wrap gap-3 md:mt-8">
          <a
            href="{{ routes.search_url }}?q={{ encoded_terms }}"
            class="min-h-6.5 shrink-0 rounded-full px-3.5 py-1.5 font-montserrat-bold text-[12px] leading-none font-bold transition hover:bg-main-blue hover:text-white md:min-h-8.5 md:px-4 md:py-2 md:text-[14px]{% if only_products == false and only_pages == false %} bg-main-blue text-white{% else %} bg-[#C0D7ED]/30 text-main-blue{% endif %}"
          >
            Усі
          </a>
          <a
            href="{{ routes.search_url }}?q={{ encoded_terms }}&type=product"
            class="min-h-6.5 shrink-0 rounded-full px-3.5 py-1.5 font-montserrat-bold text-[12px] leading-none font-bold transition hover:bg-main-blue hover:text-white md:min-h-8.5 md:px-4 md:py-2 md:text-[14px]{% if only_products %} bg-main-blue text-white{% else %} bg-[#C0D7ED]/30 text-main-blue{% endif %}"
          >
            Товари
          </a>
          <a
            href="{{ routes.search_url }}?q={{ encoded_terms }}&type=article,page"
            class="min-h-6.5 shrink-0 rounded-full px-3.5 py-1.5 font-montserrat-bold text-[12px] leading-none font-bold transition hover:bg-main-blue hover:text-white md:min-h-8.5 md:px-4 md:py-2 md:text-[14px]{% if only_pages %} bg-main-blue text-white{% else %} bg-[#C0D7ED]/30 text-main-blue{% endif %}"
          >
            Сторінки та статті
          </a>
        </div>

        <p class="mt-6 font-montserrat-bold text-[14px] leading-tight font-bold text-main-blue md:mt-8 md:text-[16px]">
          Кількість результатів за запитом «{{ search.terms }}»: {{ search.results_count }}
        </p>
      {%- endif -%}

      {%- paginate search.results by section.settings.results_per_page -%}
        {%- if search.results_count > 0 -%}
          <div class="mt-6 grid grid-cols-2 gap-5 md:mt-8 md:grid-cols-4 md:gap-7">
            {%- for item in search.results -%}
              {%- if item.object_type == 'product' -%}
                <article class="relative flex min-w-0 flex-col">
                  <a href="{{ item.url }}" class="mb-4 flex aspect-square w-full items-center justify-center overflow-hidden md:mb-7">
                    {%- if item.featured_image -%}
                      <img
                        class="h-full w-full object-contain"
                        src="{{ item.featured_image | image_url: width: 700 }}"
                        alt="{{ item.title | escape }}"
                        loading="lazy"
                      >
                    {%- else -%}
                      <img class="h-full w-full object-contain" src="{{ 'product.webp' | asset_url }}" alt="{{ item.title | escape }}" loading="lazy">
                    {%- endif -%}
                  </a>

                  <div class="flex flex-1 flex-col items-stretch md:items-start">
                    <a href="{{ item.url }}">
                      <h3 class="font-montserrat-bold text-[13px] leading-[1.18] font-bold text-dark-blue transition hover:text-main-blue md:min-h-15 md:max-w-75 md:text-[16px]">
                        {{ item.title }}
                      </h3>
                    </a>

                    <div class="mt-4 hidden min-h-5 flex-wrap gap-2 md:flex">
                      {%- unless item.has_only_default_variant -%}
                        {%- for variant in item.variants limit: 4 -%}
                          <span class="rounded-lg bg-[#C0D7ED]/20 px-2 py-0.5 font-montserrat-bold text-[16px] leading-none font-bold text-main-blue/70">
                            {{ variant.title }}
                          </span>
                        {%- endfor -%}
                      {%- endunless -%}
                    </div>

                    <a
                      class="mt-4 flex min-h-9 w-full items-center justify-center rounded-[10px] border border-main-blue text-center font-montserrat-bold text-[12px] leading-none font-bold text-main-blue transition hover:-translate-y-0.5 hover:border-dark-blue hover:bg-dark-blue hover:text-white hover:shadow-[0_14px_28px_rgba(0,65,114,0.2)] focus-visible:-translate-y-0.5 focus-visible:border-dark-blue focus-visible:bg-dark-blue focus-visible:text-white md:min-h-13 md:rounded-[14px] md:text-[14px]"
                      href="{{ item.url }}"
                    >
                      <span class="hidden md:inline">Детальніше</span>
                      <img class="h-5 w-5 md:hidden" src="{{ 'cart-icon.svg' | asset_url }}" alt="" aria-hidden="true">
                    </a>
                  </div>
                </article>
              {%- else -%}
                <a
                  href="{{ item.url }}"
                  class="group col-span-2 flex flex-col gap-2 rounded-2xl border border-[#C0D7ED] p-5 transition hover:border-main-blue md:p-6"
                >
                  <span class="w-fit rounded-full bg-[#C0D7ED]/20 px-3 py-1 font-montserrat-bold text-[11px] leading-none font-bold text-main-blue uppercase">
                    {% if item.object_type == 'article' %}Стаття{% else %}Сторінка{% endif %}
                  </span>
                  <h3 class="font-montserrat-bold text-[16px] leading-tight font-bold text-dark-blue transition group-hover:text-main-blue md:text-[18px]">
                    {{ item.title }}
                  </h3>
                  <p class="line-clamp-2 font-montserrat-reg text-[13px] leading-tight text-main-blue/70 md:text-[14px]">
                    {{ item.content | strip_html | truncatewords: 24 }}
                  </p>
                </a>
              {%- endif -%}
            {%- endfor -%}
          </div>

          {%- if paginate.pages > 1 -%}
            <nav class="mt-10 flex items-center justify-center gap-2 md:mt-14" aria-label="Пагінація">
              {%- if paginate.previous -%}
                <a
                  href="{{ paginate.previous.url }}"
                  class="grid h-10 w-10 place-items-center rounded-full border border-[#C0D7ED] text-main-blue transition hover:border-main-blue hover:bg-main-blue hover:text-white"
                  aria-label="Попередня сторінка"
                  >‹</a
                >
              {%- endif -%}

              {%- for part in paginate.parts -%}
                {%- if part.is_link -%}
                  <a
                    href="{{ part.url }}"
                    class="grid h-10 w-10 place-items-center rounded-full border border-[#C0D7ED] font-montserrat-bold text-[14px] font-bold text-main-blue transition hover:border-main-blue hover:bg-main-blue hover:text-white"
                  >
                    {{ part.title }}
                  </a>
                {%- else -%}
                  <span class="grid h-10 w-10 place-items-center rounded-full font-montserrat-bold text-[14px] font-bold {% if part.title == paginate.current_page %}bg-main-blue text-white{% else %}text-main-blue{% endif %}">
                    {{ part.title }}
                  </span>
                {%- endif -%}
              {%- endfor -%}

              {%- if paginate.next -%}
                <a
                  href="{{ paginate.next.url }}"
                  class="grid h-10 w-10 place-items-center rounded-full border border-[#C0D7ED] text-main-blue transition hover:border-main-blue hover:bg-main-blue hover:text-white"
                  aria-label="Наступна сторінка"
                  >›</a
                >
              {%- endif -%}
            </nav>
          {%- endif -%}
        {%- else -%}
          <div class="mx-auto mt-8 flex max-w-155 flex-col items-center gap-6 rounded-2xl border border-[#C0D7ED] px-4 py-10 text-center md:mt-10 md:gap-8 md:px-16 md:py-16">
            <img class="h-24 w-auto object-contain md:h-32" src="{{ 'big-turtle.webp' | asset_url }}" alt="">

            <div class="flex flex-col gap-2 md:gap-4">
              <h2 class="font-montserrat-bold text-[22px] leading-tight font-bold text-dark-blue md:text-[32px]">Нічого не знайдено</h2>
              <p class="font-montserrat-reg text-[14px] leading-tight text-main-blue/70 md:text-[16px]">
                За запитом «{{ search.terms }}» ми нічого не знайшли. Спробуйте інше формулювання або перегляньте каталог.
              </p>
            </div>

            <a
              href="{{ routes.all_products_collection_url }}"
              class="mt-2 inline-flex min-h-12 items-center justify-center rounded-[10px] bg-main-blue px-8 text-center font-montserrat-bold text-[12px] leading-none font-bold text-white transition hover:bg-dark-blue focus-visible:bg-dark-blue md:rounded-[14px] md:px-10 md:text-[14px]"
            >
              Переглянути каталог
            </a>
          </div>
        {%- endif -%}
      {%- endpaginate -%}
    {%- endif -%}
  </div>
</section>

{% schema %}
{
  "name": "MP Search",
  "settings": [
    {
      "type": "range",
      "id": "results_per_page",
      "label": "Results per page",
      "min": 4,
      "max": 36,
      "step": 4,
      "default": 24
    }
  ]
}
{% endschema %}
