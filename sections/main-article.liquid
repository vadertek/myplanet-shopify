{% render 'mp-breadcrumb' %}

<article class="mx-auto max-w-360 bg-white px-4 py-8 md:px-8 md:py-14">
  <div class="mx-auto max-w-155">
    <div class="flex flex-wrap items-center gap-2">
      {%- if article.tags.size > 0 -%}
        <span class="w-fit rounded-2xl bg-[#C0D7ED4D] px-2 py-1 font-montserrat-bold text-[12px] leading-none font-bold text-dark-blue">
          {{ article.tags.first }}
        </span>
      {%- endif -%}

      {%- if section.settings.show_date -%}
        <span class="font-montserrat-reg text-[12px] leading-none text-main-blue/70">{{ article.published_at | date: '%d.%m.%Y' }}</span>
      {%- endif -%}

      {%- if section.settings.show_author and article.author != blank -%}
        <span class="font-montserrat-reg text-[12px] leading-none text-main-blue/70">{{ article.author }}</span>
      {%- endif -%}
    </div>

    <h1 class="mt-4 font-montserrat-bold text-[28px] leading-tight font-bold text-dark-blue md:text-[40px]">{{ article.title }}</h1>

    {%- if article.image -%}
      <img
        class="mt-6 aspect-[1.6] w-full rounded-2xl object-cover md:mt-8"
        src="{{ article.image | image_url: width: 1400 }}"
        alt="{{ article.image.alt | escape }}"
        loading="eager"
      >
    {%- endif -%}

    <div
      class="mt-8 font-montserrat-reg text-[15px] leading-[1.6] text-main-blue md:text-[16px] [&_a]:text-main-blue [&_a]:underline [&_a]:transition [&_a]:hover:text-dark-blue [&_blockquote]:border-l-4 [&_blockquote]:border-main-blue [&_blockquote]:pl-4 [&_blockquote]:text-main-blue/70 [&_blockquote]:italic [&_h2]:mt-8 [&_h2]:mb-3 [&_h2]:font-montserrat-bold [&_h2]:text-[22px] [&_h2]:font-bold [&_h2]:leading-tight [&_h2]:text-dark-blue [&_h3]:mt-6 [&_h3]:mb-2 [&_h3]:font-montserrat-bold [&_h3]:text-[18px] [&_h3]:font-bold [&_h3]:leading-tight [&_h3]:text-dark-blue [&_img]:my-6 [&_img]:rounded-2xl [&_li]:mb-1 [&_ol]:mb-4 [&_ol]:list-decimal [&_ol]:pl-5 [&_p]:mb-4 [&_ul]:mb-4 [&_ul]:list-disc [&_ul]:pl-5"
    >
      {{ article.content }}
    </div>

    <div class="mt-10 flex flex-wrap items-center justify-between gap-4 border-t border-[#C0D7ED]/30 pt-6 md:mt-14">
      <a href="{{ blog.url }}" class="inline-flex items-center gap-2 font-montserrat-bold text-[13px] leading-none font-bold text-main-blue transition hover:text-dark-blue">
        <span aria-hidden="true">←</span>
        Всі статті
      </a>

      <button
        id="mp-article-share-{{ section.id }}"
        type="button"
        class="inline-flex items-center gap-2 rounded-full border border-[#C0D7ED] px-4 py-2 font-montserrat-bold text-[12px] leading-none font-bold text-main-blue transition hover:border-main-blue hover:bg-main-blue hover:text-white"
        data-url="{{ request.origin }}{{ article.url }}"
        data-title="{{ article.title | escape }}"
      >
        <span data-share-label>Поділитися</span>
      </button>
    </div>
  </div>
</article>

<script>
  (function () {
    function initArticleShare() {
      const button = document.getElementById('mp-article-share-{{ section.id }}');
      if (!button || button.shareReady) return;
      button.shareReady = true;

      const label = button.querySelector('[data-share-label]');
      const url = button.dataset.url;
      const title = button.dataset.title;

      button.addEventListener('click', function () {
        if (navigator.share) {
          navigator.share({ title: title, url: url }).catch(function () {});
          return;
        }

        navigator.clipboard.writeText(url).then(function () {
          if (!label) return;
          const original = label.textContent;
          label.textContent = 'Посилання скопійовано';
          setTimeout(function () {
            label.textContent = original;
          }, 2000);
        });
      });
    }

    if (document.readyState === 'loading') {
      document.addEventListener('DOMContentLoaded', initArticleShare);
    } else {
      initArticleShare();
    }

    document.addEventListener('shopify:section:load', function (event) {
      if (event.target && event.target.querySelector('#mp-article-share-{{ section.id }}')) {
        initArticleShare();
      }
    });
  })();
</script>

<script type="application/ld+json">
  {{ article | structured_data }}
</script>

{% schema %}
{
  "name": "MP Article",
  "settings": [
    {
      "type": "checkbox",
      "id": "show_date",
      "label": "Show date",
      "default": true
    },
    {
      "type": "checkbox",
      "id": "show_author",
      "label": "Show author",
      "default": false
    }
  ]
}
{% endschema %}
