{%- liquid
  assign products_to_show = section.settings.products_to_show | default: 8
-%}

<!-- In Trends -->
<section id="mp-home-trends-{{ section.id }}" class="overflow-hidden bg-white px-4 py-8 md:py-10">
  <div class="mx-auto max-w-340">
    <h2 class="mb-5 font-montserrat-bold text-[32px] leading-none font-bold text-main-blue md:mb-10 md:text-[40px]">
      {{ section.settings.title | escape }}
    </h2>

    {%- if section.blocks.size > 0 -%}
      <div class="-mx-8 flex items-center justify-between gap-6 px-8 md:-mx-4 md:px-4">
        <div
          class="scrollbar-none flex min-w-0 gap-3 overflow-x-auto pr-8 [&::-webkit-scrollbar]:hidden"
          aria-label="Теги продуктів"
        >
          {%- for block in section.blocks -%}
            <button
              id="trends-tag-button-{{ section.id }}-{{ block.id }}"
              class="min-h-6.5 shrink-0 cursor-pointer rounded-full px-3.5 py-1.5 font-montserrat-bold text-[12px] leading-none font-bold transition hover:bg-main-blue hover:text-white focus-visible:bg-main-blue focus-visible:text-white md:min-h-8.5 md:px-4 md:py-2 md:text-[14px]{% if forloop.first %} bg-main-blue text-white{% else %} bg-[#C0D7ED]/30 text-main-blue{% endif %}"
              type="button"
              aria-selected="{% if forloop.first %}true{% else %}false{% endif %}"
              {{ block.shopify_attributes }}
            >
              {%- if block.settings.title != blank -%}
                {{ block.settings.title }}
              {%- elsif block.type == 'collection' and block.settings.collection != blank -%}
                {{ block.settings.collection.title }}
              {%- else -%}
                Tag
              {%- endif -%}
            </button>
          {%- endfor -%}
        </div>
      </div>

      {%- for block in section.blocks -%}
        {%- liquid
          assign block_products = block.settings.products

          if block.type == 'collection'
            assign block_collection = block.settings.collection
            assign block_products = block_collection.products
          endif
        -%}
        <div
          id="trends-tag-panel-{{ section.id }}-{{ block.id }}"
          class="{% unless forloop.first %}hidden{% endunless %}"
        >
          {%- if block_products.count > 0 -%}
            <div
              id="trends-swiper-{{ section.id }}-{{ block.id }}"
              class="swiper overflow-hidden pt-7 md:overflow-visible md:pt-9"
            >
              <div class="swiper-wrapper flex md:grid md:transform-none md:grid-cols-4 md:gap-7">
                {%- for product in block_products limit: products_to_show -%}
                  {%- liquid
                    assign buy_variant = product.selected_or_first_available_variant

                    if buy_variant == blank or buy_variant.available == false
                      assign buy_variant = product.variants | where: 'available', true | first
                    endif
                  -%}
                  <article class="swiper-slide relative flex h-full w-full min-w-0 shrink-0 flex-col md:w-auto md:shrink">
                    <a class="mb-5 flex aspect-square w-full items-center justify-center overflow-hidden md:mb-7" href="{{ product.url }}">
                      {%- if product.featured_image -%}
                        <img
                          class="h-full w-full object-contain"
                          src="{{ product.featured_image | image_url: width: 700 }}"
                          alt="Product image"
                          loading="lazy"
                        >
                      {%- else -%}
                        <div class="flex h-full w-full items-center justify-center rounded-[10px] bg-[#C0D7ED]/20 px-5 text-center font-montserrat-bold text-[12px] leading-tight text-[#527FA1] md:text-[14px]">
                          NO IMAGE
                        </div>
                      {%- endif -%}
                    </a>

                    <div class="flex flex-1 flex-col items-stretch md:items-start">
                      <h3 class="max-w-58 font-montserrat-bold text-[13px] leading-[1.18] font-bold text-dark-blue md:min-h-15 md:max-w-75 md:text-[16px]">
                        <a href="{{ product.url }}">{{ product.title | escape }}</a>
                      </h3>

                      <div class="mt-4 hidden min-h-7 flex-wrap gap-2 md:flex">
                        {%- unless product.has_only_default_variant -%}
                          {%- for variant in product.variants limit: 4 -%}
                            <span class="rounded-lg bg-[#C0D7ED]/20 px-2 py-0.5 font-montserrat-bold text-[16px] leading-none font-bold text-main-blue/70">
                              {{ variant.title }}
                            </span>
                          {%- endfor -%}
                        {%- endunless -%}
                      </div>

                      <div class="mt-2.5 flex min-h-5 items-center gap-1.5 font-montserrat-reg text-[10px] leading-none text-[#C0D7ED] md:gap-2 md:text-[12px] pb-3">
                        <img class="w-19 md:w-22.5" src="{{ 'sky-start.webp' | asset_url }}" alt="Rating stars">
                        <span>4.9 (178)</span>
                      </div>

                      {%- if buy_variant and buy_variant.available and buy_variant.price > 0 -%}
                        <form class="mt-auto w-full" action="{{ routes.cart_add_url }}" method="post">
                          <input type="hidden" name="id" value="{{ buy_variant.id }}">
                          <input type="hidden" name="quantity" value="1">

                          <button
                            class="flex min-h-9 w-full cursor-pointer items-center justify-center rounded-[10px] border border-main-blue bg-main-blue text-center font-montserrat-bold text-[12px] leading-none font-bold text-white transition hover:-translate-y-0.5 hover:border-dark-blue hover:bg-dark-blue hover:shadow-[0_14px_28px_rgba(0,65,114,0.2)] focus-visible:-translate-y-0.5 focus-visible:border-dark-blue focus-visible:bg-dark-blue md:min-h-13 md:rounded-[14px] md:text-[14px]"
                            type="submit"
                            aria-label="{{ 'general.custom.buy-for' | t }} {{ product.title | escape }}"
                          >
                            {{ 'general.custom.buy-for' | t }}
                            {{ buy_variant.price | money_without_currency | replace: ',00', '' | replace: '.00', '' }} ₴
                          </button>
                        </form>
                      {%- else -%}
                        <button
                          class="mt-auto flex min-h-9 w-full cursor-not-allowed items-center justify-center rounded-[10px] border border-[#C0D7ED] bg-white text-center font-montserrat-bold text-[12px] leading-none font-bold text-[#C0D7ED] md:min-h-13 md:rounded-[14px] md:text-[14px]"
                          type="button"
                          disabled
                        >
                          {{ 'general.custom.unavailable' | t }}
                        </button>
                      {%- endif -%}
                    </div>
                  </article>
                {%- endfor -%}
              </div>
            </div>
          {%- else -%}
            <p class="pt-8 font-montserrat-bold text-[16px] leading-tight font-bold text-main-blue">У цьому тегу поки немає продуктів.</p>
          {%- endif -%}
        </div>
      {%- endfor -%}

      <div class="mx-auto mt-8 flex h-9 w-22 overflow-hidden rounded-full bg-[#C0D7ED]/30 md:hidden" aria-label="Навігація товарів">
        <button
          id="trends-swiper-prev-{{ section.id }}"
          class="grid h-9 w-11 cursor-pointer place-items-center transition hover:bg-main-blue/10 focus-visible:bg-main-blue/10"
          type="button"
          aria-label="Попередні товари"
        >
          <span class="h-3.5 w-3.5 rotate-45 border-b-2 border-l-2 border-main-blue" aria-hidden="true"></span>
        </button>
        <button
          id="trends-swiper-next-{{ section.id }}"
          class="grid h-9 w-11 cursor-pointer place-items-center transition hover:bg-main-blue/10 focus-visible:bg-main-blue/10"
          type="button"
          aria-label="Наступні товари"
        >
          <span class="h-3.5 w-3.5 rotate-225 border-b-2 border-l-2 border-main-blue" aria-hidden="true"></span>
        </button>
      </div>
    {%- else -%}
      <p class="font-montserrat-bold text-[16px] leading-tight font-bold text-main-blue">Додайте тег і продукти в блоках секції.</p>
    {%- endif -%}
  </div>
</section>

<script>
  (function () {
    function initHomeTrends() {
      const root = document.getElementById('mp-home-trends-{{ section.id }}');
      if (!root || root.homeTrendsReady) return;

      root.homeTrendsReady = true;

      {%- for block in section.blocks -%}
        const button{{ forloop.index }} = document.getElementById('trends-tag-button-{{ section.id }}-{{ block.id }}');
        const panel{{ forloop.index }} = document.getElementById('trends-tag-panel-{{ section.id }}-{{ block.id }}');
        const swiperEl{{ forloop.index }} = document.getElementById('trends-swiper-{{ section.id }}-{{ block.id }}');
      {%- endfor -%}

      const buttons = [
        {%- for block in section.blocks -%}
          button{{ forloop.index }}{% unless forloop.last %},{% endunless %}
        {%- endfor -%}
      ].filter(Boolean);

      const panels = [
        {%- for block in section.blocks -%}
          panel{{ forloop.index }}{% unless forloop.last %},{% endunless %}
        {%- endfor -%}
      ].filter(Boolean);

      const swipers = [
        {%- for block in section.blocks -%}
          swiperEl{{ forloop.index }}{% unless forloop.last %},{% endunless %}
        {%- endfor -%}
      ].filter(Boolean);

      const nextBtn = document.getElementById('trends-swiper-next-{{ section.id }}');
      const prevBtn = document.getElementById('trends-swiper-prev-{{ section.id }}');

      function initSwiper(index) {
        const swiperEl = swipers[index];
        if (!swiperEl || typeof Swiper === 'undefined') return;

        if (window.matchMedia('(min-width: 768px)').matches) {
          if (swiperEl.swiper) swiperEl.swiper.destroy(true, true);
          return;
        }

        if (swiperEl.swiper) swiperEl.swiper.destroy(true, true);

        new Swiper(swiperEl, {
          slidesPerView: 1,
          speed: 350,
          watchOverflow: true,
          navigation: {
            nextEl: nextBtn || null,
            prevEl: prevBtn || null,
          },
        });
      }

      function setActive(index) {
        buttons.forEach(function (button, buttonIndex) {
          const active = buttonIndex === index;

          button.setAttribute('aria-selected', String(active));
          button.classList.toggle('bg-main-blue', active);
          button.classList.toggle('text-white', active);
          button.classList.toggle('bg-[#C0D7ED]/30', !active);
          button.classList.toggle('text-main-blue', !active);
        });

        panels.forEach(function (panel, panelIndex) {
          panel.classList.toggle('hidden', panelIndex !== index);
        });

        initSwiper(index);
      }

      buttons.forEach(function (button, index) {
        button.addEventListener('click', function () {
          setActive(index);
          button.scrollIntoView({ behavior: 'smooth', block: 'nearest', inline: 'center' });
        });
      });

      setActive(0);

      window.addEventListener('resize', function () {
        const activeIndex = buttons.findIndex(function (button) {
          return button.getAttribute('aria-selected') === 'true';
        });

        initSwiper(activeIndex >= 0 ? activeIndex : 0);
      });
    }

    if (document.readyState === 'loading') {
      document.addEventListener('DOMContentLoaded', initHomeTrends);
    } else {
      initHomeTrends();
    }

    document.addEventListener('shopify:section:load', function (event) {
      if (event.target && event.target.querySelector('#mp-home-trends-{{ section.id }}')) {
        initHomeTrends();
      }
    });
  })();
</script>

{% schema %}
{
  "name": "MP home trends",
  "settings": [
    {
      "type": "text",
      "id": "title",
      "label": "Title",
      "default": "Зараз в тренді"
    },
    {
      "type": "range",
      "id": "products_to_show",
      "min": 1,
      "max": 24,
      "step": 1,
      "label": "Products to show",
      "default": 8
    }
  ],
  "blocks": [
    {
      "type": "product_tag",
      "name": "Product tag",
      "settings": [
        {
          "type": "text",
          "id": "title",
          "label": "Tag title",
          "default": "Tag"
        },
        {
          "type": "product_list",
          "id": "products",
          "label": "Products",
          "limit": 24
        }
      ]
    },
    {
      "type": "collection",
      "name": "Collection",
      "settings": [
        {
          "type": "collection",
          "id": "collection",
          "label": "Collection"
        },
        {
          "type": "text",
          "id": "title",
          "label": "Tag title"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "MP home trends",
      "blocks": [
        {
          "type": "product_tag",
          "settings": {
            "title": "Всі"
          }
        }
      ]
    }
  ]
}
{% endschema %}
