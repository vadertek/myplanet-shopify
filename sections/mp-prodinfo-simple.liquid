<section class="px-4 py-10 md:px-10 md:py-20">
  <div class="mx-auto grid max-w-340 gap-8 md:grid-cols-[minmax(0,1fr)_minmax(0,860px)] md:items-center md:gap-10">
    <h2 class="font-montserrat-bold text-[32px] leading-none font-bold text-[#236591] md:text-[36px]">{{ section.settings.title }}</h2>

    <div class="grid grid-cols-2 gap-3 md:grid-cols-4 md:gap-4">
      {%- for block in section.blocks -%}
        <article>
          {%- if block.settings.image != blank -%}
            {{ block.settings.image | image_url: width: 320 | image_tag: class: 'aspect-square w-full rounded-[14px] object-cover', loading: 'lazy', alt: 'Icon' }}
          {%- else -%}
            <img class="aspect-square w-full rounded-[14px] object-cover" src="{{ 'use.webp' | asset_url  }}" alt="Item">
          {%- endif -%}

          <h3 class="mt-3 font-montserrat-bold text-[14px] leading-none font-bold text-[#236591]">{{ block.settings.text }}</h3>
        </article>
      {%- endfor -%}
    </div>
  </div>
</section>

{% schema %}
{
  "name": "MP - Simple Uses",
  "settings": [
    {
      "type": "text",
      "id": "title",
      "label": "Title",
      "default": "Просте використання"
    }
  ],
  "max_blocks": 4,
  "blocks": [
    {
      "type": "icons",
      "name": "Icons List",
      "settings": [
        {
          "type": "image_picker",
          "id": "image",
          "label": "Image"
        },
        {
          "type": "text",
          "id": "text",
          "label": "text",
          "default": "Розпиліть засіб на поверхню."
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "MP - Simple Uses"
    }
  ]
}
{% endschema %}
