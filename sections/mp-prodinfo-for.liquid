<section class="px-4 py-10 md:px-10 md:py-20">
  <div class="mx-auto max-w-360">
    <h2 class="mb-10 font-montserrat-bold text-[32px] leading-none font-bold text-[#3FA11F] md:mb-14 md:text-[40px]">{{ section.settings.title }}</h2>

    <div class="grid grid-cols-2 gap-x-4 gap-y-8 sm:grid-cols-4 md:grid-cols-8 md:gap-x-2 md:gap-y-0">
      {%- for block in section.blocks -%}
        <article class="flex flex-col items-center text-center">
          <div class="flex h-18 w-full items-center justify-center md:h-20">
            {%- if block.settings.image != blank -%}
              {{ block.settings.image | image_url: width: 320 | image_tag: class: 'w-full object-contain', loading: 'lazy', alt: 'Icon' }}
            {%- else -%}
              <img class="w-full object-contain" src="{{ 'duhovka.webp' | asset_url  }}" alt="Item">
            {%- endif -%}
          </div>
          <h3 class="mt-5 max-w-26 font-montserrat-bold text-[16px] leading-[1.05] font-bold text-[#3FA11F]">{{ block.settings.text }}</h3>
        </article>
      {%- endfor -%}
    </div>
  </div>
</section>

{% schema %}
{
  "name": "MP - Good For",
  "settings": [
    {
      "type": "text",
      "id": "title",
      "label": "Title",
      "default": "Підходить для"
    }
  ],
  "max_blocks": 8,
  "blocks": [
    {
      "type": "icons",
      "name": "Icons List",
      "settings": [
        {
          "type": "image_picker",
          "id": "image",
          "label": "Image"
        },
        {
          "type": "text",
          "id": "text",
          "label": "text",
          "default": "Кухонних Поверхонь"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "MP - Good For"
    }
  ]
}
{% endschema %}
