<section id="mp-collection-grid-{{ section.id }}" class="overflow-hidden bg-white px-4 py-8 md:py-10">
  <div class="mx-auto max-w-340">
    {%- if section.blocks.size > 0 -%}
      <div class="-mx-8 px-8 md:-mx-4 md:px-4">
        <div class="scrollbar-none flex min-w-0 gap-3 overflow-x-auto pr-8 [&::-webkit-scrollbar]:hidden" aria-label="Теги продуктів">
          {%- for block in section.blocks -%}
            <button
              id="collection-tag-button-{{ section.id }}-{{ block.id }}"
              class="min-h-6.5 shrink-0 cursor-pointer rounded-full px-3.5 py-1.5 font-montserrat-bold text-[12px] leading-none font-bold transition hover:bg-main-blue hover:text-white focus-visible:bg-main-blue focus-visible:text-white md:min-h-8.5 md:px-4 md:py-2 md:text-[14px]{% if forloop.first %} bg-main-blue text-white{% else %} bg-[#C0D7ED]/30 text-main-blue{% endif %}"
              type="button"
              aria-selected="{% if forloop.first %}true{% else %}false{% endif %}"
              {{ block.shopify_attributes }}
            >
              {{ block.settings.title }}
            </button>
          {%- endfor -%}
        </div>
      </div>

      {%- for block in section.blocks -%}
        <div
          id="collection-tag-panel-{{ section.id }}-{{ block.id }}"
          class="{% unless forloop.first %}hidden{% endunless %}"
        >
          {%- if block.settings.products.count > 0 -%}
            <div class="grid grid-cols-2 gap-5 pt-8 md:grid-cols-4 md:gap-7 md:pt-10">
              {%- for product in block.settings.products -%}
                <article class="relative flex min-w-0 flex-col">
                  <a href="{{ product.url }}" class="mb-4 flex aspect-square w-full items-center justify-center overflow-hidden md:mb-7">
                    {%- if product.featured_image -%}
                      <img
                        class="h-full w-full object-contain"
                        src="{{ product.featured_image | image_url: width: 700 }}"
                        alt="{{ product.title | escape }}"
                        loading="lazy"
                      >
                    {%- else -%}
                      <img class="h-full w-full object-contain" src="{{ 'product.webp' | asset_url }}" alt="{{ product.title | escape }}" loading="lazy">
                    {%- endif -%}
                  </a>

                  <div class="flex flex-1 flex-col items-stretch md:items-start">
                    <a href="{{ product.url }}">
                      <h3 class="font-montserrat-bold text-[13px] leading-[1.18] font-bold text-dark-blue transition hover:text-main-blue md:min-h-15 md:max-w-75 md:text-[16px]">
                        {{ product.title }}
                      </h3>
                    </a>

                    <div class="mt-4 hidden min-h-5 flex-wrap gap-2 md:flex">
                      {%- unless product.has_only_default_variant -%}
                        {%- for variant in product.variants limit: 4 -%}
                          <span class="rounded-lg bg-[#C0D7ED]/20 px-2 py-0.5 font-montserrat-bold text-[16px] leading-none font-bold text-main-blue/70">
                            {{ variant.title }}
                          </span>
                        {%- endfor -%}
                      {%- endunless -%}
                    </div>

                    <a
                      class="mt-4 flex min-h-9 w-full items-center justify-center rounded-[10px] border border-main-blue text-center font-montserrat-bold text-[12px] leading-none font-bold text-main-blue transition hover:-translate-y-0.5 hover:border-dark-blue hover:bg-dark-blue hover:text-white hover:shadow-[0_14px_28px_rgba(0,65,114,0.2)] focus-visible:-translate-y-0.5 focus-visible:border-dark-blue focus-visible:bg-dark-blue focus-visible:text-white md:min-h-13 md:rounded-[14px] md:text-[14px]"
                      href="{{ product.url }}"
                    >
                      <span class="hidden md:inline">{{ 'general.custom.details' | t }}</span>
                      <img class="h-5 w-5 md:hidden" src="{{ 'cart-icon.svg' | asset_url }}" alt="" aria-hidden="true">
                    </a>
                  </div>
                </article>
              {%- endfor -%}
            </div>
          {%- else -%}
            <p class="pt-8 font-montserrat-bold text-[16px] leading-tight font-bold text-main-blue">У цьому тегу поки немає продуктів.</p>
          {%- endif -%}
        </div>
      {%- endfor -%}
    {%- else -%}
      <p class="font-montserrat-bold text-[16px] leading-tight font-bold text-main-blue">Додайте тег і продукти в блоках секції.</p>
    {%- endif -%}
  </div>
</section>

{% render 'mp-collections-js', section: section, active_bg_class: 'bg-main-blue', inactive_text_class: 'text-main-blue' %}

{% schema %}
{
  "name": "MP Collection Grid",
  "blocks": [
    {
      "type": "product_tag",
      "name": "Product tag",
      "settings": [
        {
          "type": "text",
          "id": "title",
          "label": "Tag title",
          "default": "Tag"
        },
        {
          "type": "product_list",
          "id": "products",
          "label": "Products",
          "limit": 24
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "MP Collection Grid",
      "blocks": [
        {
          "type": "product_tag",
          "settings": {
            "title": "Всі"
          }
        }
      ]
    }
  ]
}
{% endschema %}
