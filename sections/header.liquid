<!-- Topbar -->
<div class="hidden h-8 w-full items-center justify-center {% if template.suffix == 'baby' %} bg-[#1EBECA] {% else %} bg-main-blue {% endif %} md:flex">
  <p class="font-montserrat-reg text-sm text-white">{{ section.settings.top_bar }}</p>
</div>

<!-- Header -->
<header id="header-{{ section.id }}" class="mx-auto max-w-360 relative border-t-2 border-main-blue bg-white md:border-t-0">
  <div class="flex items-center justify-between px-4 py-3 md:px-7 md:py-4">
    <!-- Logo -->
    <a href="/">
      <img loading="eager" class="h-8 md:h-10" src="{{ 'header-logo.webp' | asset_url }}" alt="My Planet">
    </a>

    <!-- Desktop Navigation -->
    <nav class="hidden md:block">
      <ul class="flex space-x-6">
        {%- for link in linklists['main-menu'].links -%}
          <li>
            <a
              href="{{ link.url }}"
              class="text-dark-blue transition duration-200 hover:text-main-blue{% if link.current %} text-main-blue{% endif %}"
            >
              {{ link.title }}
            </a>
          </li>
        {%- endfor -%}
      </ul>
    </nav>

    <!-- Actions -->
    <div class="flex items-center gap-5 md:space-x-4">
      {% render 'mp-header-search' %}

      <a class="relative inline-flex h-7 w-7 items-center justify-center" href="{{ routes.cart_url }}" data-cherie-cart-open aria-haspopup="dialog">
        <img loading="eager" class="h-5 md:h-4" src="{{ 'cart-icon.svg' | asset_url }}" alt="Кошик">
        <span
          class="absolute -top-1 -right-1 grid h-4 min-w-4 place-items-center rounded-full border border-white bg-main-blue px-1 font-montserrat-bold text-[10px] leading-none font-bold text-white shadow-[0_4px_10px_rgba(0,128,199,0.25)]{% if cart.item_count == 0 %} hidden{% endif %}"
          data-cherie-cart-count-badge
          aria-hidden="true"
        >
          <span data-cherie-cart-count>{{ cart.item_count }}</span>
        </span>
      </a>
      <button
        id="header-burger-{{ section.id }}"
        type="button"
        class="flex h-8 w-8 flex-col items-center justify-center gap-1.5 md:hidden"
        aria-label="Відкрити меню"
        aria-expanded="false"
      >
        <span id="header-burger-top-{{ section.id }}" class="h-0.5 w-5 rounded-full bg-main-blue transition duration-200"></span>
        <span id="header-burger-middle-{{ section.id }}" class="h-0.5 w-5 rounded-full bg-main-blue transition duration-200"></span>
        <span id="header-burger-bottom-{{ section.id }}" class="h-0.5 w-5 rounded-full bg-main-blue transition duration-200"></span>
      </button>
    </div>
  </div>

  <!-- Mobile Navigation -->
  <nav
    id="header-mobile-menu-{{ section.id }}"
    class="pointer-events-none absolute right-0 left-0 z-20 max-h-0 -translate-y-2 overflow-hidden bg-white px-4 opacity-0 shadow-lg transition-all duration-300 md:hidden"
  >
    <ul class="flex flex-col gap-4 py-5">
      {%- for link in linklists['main-menu'].links -%}
        <li>
          <a
            href="{{ link.url }}"
            class="block text-dark-blue transition duration-200 hover:text-main-blue{% if link.current %} text-main-blue{% endif %}"
          >
            {{ link.title }}
          </a>
        </li>
      {%- endfor -%}
    </ul>
  </nav>
</header>

<script>
  (function () {
    function initHeader() {
      const burger = document.getElementById('header-burger-{{ section.id }}');
      const menu = document.getElementById('header-mobile-menu-{{ section.id }}');
      const topLine = document.getElementById('header-burger-top-{{ section.id }}');
      const middleLine = document.getElementById('header-burger-middle-{{ section.id }}');
      const bottomLine = document.getElementById('header-burger-bottom-{{ section.id }}');

      if (!burger || !menu || burger.headerReady) return;
      burger.headerReady = true;

      burger.addEventListener('click', function () {
        const isOpen = burger.getAttribute('aria-expanded') === 'true';

        burger.setAttribute('aria-expanded', String(!isOpen));

        menu.classList.toggle('max-h-0', isOpen);
        menu.classList.toggle('max-h-80', !isOpen);
        menu.classList.toggle('-translate-y-2', isOpen);
        menu.classList.toggle('translate-y-0', !isOpen);
        menu.classList.toggle('opacity-0', isOpen);
        menu.classList.toggle('opacity-100', !isOpen);
        menu.classList.toggle('pointer-events-none', isOpen);
        menu.classList.toggle('pointer-events-auto', !isOpen);

        topLine?.classList.toggle('translate-y-2', !isOpen);
        topLine?.classList.toggle('rotate-45', !isOpen);
        middleLine?.classList.toggle('opacity-0', !isOpen);
        bottomLine?.classList.toggle('-translate-y-2', !isOpen);
        bottomLine?.classList.toggle('-rotate-45', !isOpen);
      });
    }

    if (document.readyState === 'loading') {
      document.addEventListener('DOMContentLoaded', initHeader);
    } else {
      initHeader();
    }

    document.addEventListener('shopify:section:load', function (event) {
      if (event.target && event.target.querySelector('#header-{{ section.id }}')) {
        initHeader();
      }
    });
  })();
</script>

{% schema %}
{
  "name": "MP - Header",
  "settings": [
    {
      "type": "text",
      "id": "top_bar",
      "label": "Top Bar Text",
      "default": "Безкоштовна доставка від 1000 грн"
    }
  ]
}
{% endschema %}
